#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: obscura-control {status|start|stop|restart|lockdown|eepsite-address}"
}

case "${1:-}" in
  status)
    systemctl --no-pager status i2pd nginx nftables
    ;;
  start)
    systemctl start i2pd nginx
    ;;
  stop)
    systemctl stop nginx i2pd
    ;;
  restart)
    systemctl restart i2pd nginx
    ;;
  lockdown)
    systemctl restart nftables
    sysctl --system
    ;;
  eepsite-address)
    echo "Open the i2pd web console: http://127.0.0.1:7070/"
    ;;
  *)
    usage
    exit 1
    ;;
esac
